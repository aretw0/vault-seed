# ===================================================================
# .gitignore para Vaults de Obsidian & Foam
# ===================================================================

# Arquivos de ambiente
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Dependências
node_modules/
.pnpm-store/
__pycache__/
__marimo__/

# Arquivos de Sistema e temporários
*~
.DS_Store
Thumbs.db
*.log
.gemini/
# Ignorar o restante do diretório .vscode/, por isso o *
# Exceções rastreadas: extensões recomendadas e configurações do Foam
.vscode/*
# Exceções rastreadas: extensões recomendadas e configurações do Foam
!.vscode/extensions.json
!.vscode/settings.json

# Pasta de lixo do Obsidian
.trash/

# ===================================================================
# Arquivos específicos do usuário - NUNCA rastrear
# ===================================================================
# Cache, estado do workspace, histórico, etc.
.obsidian/cache
.obsidian/workspace.json
.obsidian/workspaces.json
.obsidian/workspace-mobile.json
.obsidian/user.json
.obsidian/graph.json
# Ignora index do Plugin Copilot
.obsidian/copilot-index-*.json
.copilot-index/
# Ignora index do Plugin Smart Composer
.smtcmp_json_db/.initial_migration_completed
.smtcmp_vector_db.tar.gz

# ===================================================================
# Arquivos de configuração de Plugins do Obsidian
# ===================================================================
# A pasta de plugins da comunidade é ignorada para evitar conflitos
# de sincronização entre diferentes dispositivos e sistemas.
# Atualizações de plugins ou mudanças de configuração em um local
# podem quebrar a instalação em outro.
#
# A lista de plugins ativados (.obsidian/community-plugins.json) É
# rastreada, permitindo que cada ambiente instale as mesmas
# versões de forma independente e segura.
#
# Consulte a documentação em 'docs/estrategia-plugins-obsidian.md'
# para mais detalhes.
.obsidian/plugins/

# Arquivos de configuração que podem conter chaves de API ou dados sensíveis.
obsidian-web-clipper-settings.json
# Esse é um template, deve ser salvo sempre sem credenciais
!99 - Meta e Anexos/config/obsidian-web-clipper-settings.json

# ===================================================================
# Arquivos de configuração do Vault - Rastrear por padrão
# ===================================================================
# As linhas abaixo estão comentadas porque os arquivos não existem
# ainda. Descomente se você criar e quiser ignorá-los.
#
# .obsidian/hotkeys.json
# .obsidian/community-plugins.json
# .obsidian/publish.json

# ===================================================================
# Específico do Foam (para VS Code)
# ===================================================================
.foam/

gha-creds-*.json

# Claude Code local overrides and worktrees
.claude/settings.local.json
.claude/worktrees/

# Pi local agent/workflow state
.pi/
.workflows/

# ===================================================================
# Astro build output
# ===================================================================
dist/
.astro/
.sandbox/
public/lab/

# ===================================================================
# Dados gerados pelo Lab (artefatos de build — regeneráveis com dgk etl)
# ===================================================================
# Estes arquivos são derivados das notas do vault e de fontes externas.
# Não os comprometa no vault de usuários — regenere com `dgk etl`.
#
# No template (vault-seed), os arquivos de exemplo permanecem rastreados
# como baseline de demonstração e são removidos pelo initialize.yml ao
# inicializar o vault do usuário.
#
# Quando dados/lab/ ultrapassar ~1 MB total, o ETL rodar diariamente ou
# as notas indexadas excederem ~500, considere migrar para SQLite local
# (`dados/lab.db`) ou um repositório de dados separado.
dados/lab/

# Social dumps
**/**/instagram-*.zip

# Debug artifacts (Playwright MCP + inspeção manual local)
.playwright-mcp/
explorar-toc-check.png
graph-drag-check.png
