---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<StarlightPage
  frontmatter={{
    title: 'Página não encontrada',
    template: 'splash',
  }}
>
  <div class="not-found" lang="pt-BR">
    <p class="not-found__code">404</p>
    <p class="not-found__msg">
      Esta nota não existe, ainda está em rascunho, ou foi movida.
    </p>
    <div class="not-found__actions">
      <a class="not-found__btn not-found__btn--primary" href={`${base}/`}>Início</a>
      <a class="not-found__btn" href={`${base}/explorar/`}>Explorar notas</a>
    </div>
  </div>
</StarlightPage>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding-block: 3rem;
    text-align: center;
  }
  .not-found__code {
    font-size: clamp(4rem, 16vw, 8rem);
    font-weight: 800;
    line-height: 1;
    color: var(--sl-color-accent);
    margin: 0;
    opacity: 0.25;
  }
  .not-found__msg {
    font-size: var(--sl-text-lg);
    color: var(--sl-color-gray-2);
    margin: 0;
    max-width: 32ch;
  }
  .not-found__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }
  .not-found__btn {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    font-size: var(--sl-text-sm);
    font-weight: 600;
    text-decoration: none;
    border: 1px solid var(--sl-color-hairline);
    color: var(--sl-color-gray-2);
    transition: border-color 0.15s, color 0.15s;
  }
  .not-found__btn--primary {
    background: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
    color: var(--sl-color-black);
  }
  .not-found__btn:hover {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
  }
  .not-found__btn--primary:hover {
    background: var(--sl-color-accent-high);
    border-color: var(--sl-color-accent-high);
    color: var(--sl-color-black);
  }
</style>
