---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import manifest from '../../lab.notebooks.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const notebooksPath = import.meta.env.VAULT_NOTEBOOKS_PATH ?? 'lab';

const notebooks = manifest
  .filter((notebook) => notebook.publish)
  .map((notebook) => ({
    title: notebook.title,
    href: `${base}/${notebooksPath}/${notebook.output}`,
    description: notebook.description,
  }));
---

<StarlightPage frontmatter={{ title: 'Lab' }}>
  <p>Notebooks interativos <a href="https://marimo.io">Marimo</a> para explorar a saúde do seu vault.</p>

  <p>
    Os notebooks são exportados como WebAssembly e publicados junto com o site durante o deploy.
    Os links abaixo ficam disponíveis após o primeiro deploy via GitHub Actions.
  </p>

  <ul class="notebook-list">
    {notebooks.map((notebook) => (
      <li data-notebook-link={notebook.href}>
        <strong>{notebook.title}</strong>
        <span>— {notebook.description}</span>
        <span class="availability" data-availability>Disponível após deploy</span>
      </li>
    ))}
  </ul>

  <p>
    Para rodar os notebooks localmente: <code>pnpm run notebooks:dev</code>
  </p>
</StarlightPage>

<script>
  for (const item of document.querySelectorAll('[data-notebook-link]')) {
    const href = item.getAttribute('data-notebook-link');
    const availability = item.querySelector('[data-availability]');
    const title = item.querySelector('strong');
    if (!href || !availability || !title) continue;

    fetch(href, { method: 'HEAD' })
      .then((response) => {
        if (!response.ok) return;
        const link = document.createElement('a');
        link.href = href;
        link.textContent = title.textContent;
        title.replaceChildren(link);
        availability.textContent = 'Publicado';
      })
      .catch(() => {});
  }
</script>

<style>
  .notebook-list {
    display: grid;
    gap: 0.75rem;
    padding-inline-start: 1.25rem;
  }

  .availability {
    display: inline-block;
    margin-inline-start: 0.5rem;
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-sm);
  }
</style>
