---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<StarlightPage
  frontmatter={{
    title: 'Bem-vindo ao Vault Seed',
    template: 'splash',
    hero: {
      image: {
        html: `<div class="hero-diagram"><pre data-language="mermaid">graph TB
  V(("vault-seed")) --> D["Diário"]
  V --> P["Projetos"]
  V --> A["Áreas"]
  V --> R["Recursos"]
  V --> Q["Arquivo"]
  P --> S(["Site publicado"])
  R -.-> P
  A -.-> P</pre></div>`,
      },
      tagline: 'Um template de vault pessoal para Obsidian — organizado, versionado e publicável como site.',
      actions: [
        {
          text: 'Começar',
          link: `${base}/meta-e-anexos/seus-primeiros-passos/`,
          icon: 'right-arrow',
          variant: 'primary',
        },
        {
          text: 'Ver o Vault',
          link: `${base}/meta-e-anexos/moc-vault-seed/`,
          icon: 'open-book',
        },
      ],
    },
  }}
>
</StarlightPage>
