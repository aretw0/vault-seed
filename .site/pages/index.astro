---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<StarlightPage
  frontmatter={{
    title: 'Bem-vindo ao Vault Seed',
    template: 'splash',
    hero: {
      image: {
        alt: 'Rede de notas interligadas brotando de uma semente central — o conceito por trás do vault-seed',
        src: `${base}/assets/vault-seed-banner.svg`,
      },
      tagline: 'Um template de vault pessoal para Obsidian — organizado, versionado e publicável como site.',
      actions: [
        {
          text: 'Começar',
          link: `${base}/meta-e-anexos/seus-primeiros-passos/`,
          icon: 'right-arrow',
          variant: 'primary',
        },
        {
          text: 'Ver o Vault',
          link: `${base}/meta-e-anexos/moc-vault-seed/`,
          icon: 'open-book',
        },
      ],
    },
  }}
>
</StarlightPage>
