---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { buildVaultExploreData } from '../lib/vault-explore';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const explore = buildVaultExploreData();
const heroNodes = explore.graph.insights.hubs.slice(0, 6);
const heroNodeIds = new Set(heroNodes.map((node) => node.id));
const heroLinks = explore.graph.links.filter((link) => heroNodeIds.has(link.source) && heroNodeIds.has(link.target));
function escapeHtml(value: string) {
  return value.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}
function truncateLabel(value: string, max = 16) {
  return value.length > max ? `${value.slice(0, max - 1)}…` : value;
}
function graphHeroHtml() {
  const center = 100;
  const radius = 58;
  const maxDegree = Math.max(1, ...heroNodes.map((node) => node.degree));
  const positioned = heroNodes.map((node, index) => {
    const angle = heroNodes.length > 1 ? (Math.PI * 2 * index) / heroNodes.length - Math.PI / 2 : 0;
    return {
      ...node,
      x: center + Math.cos(angle) * radius,
      y: center + Math.sin(angle) * radius,
      size: 5 + Math.min(9, node.degree * 1.15),
      weight: 0.72 + (node.degree / maxDegree) * 0.6,
    };
  });
  const byId = new Map(positioned.map((node) => [node.id, node]));
  const lines = heroLinks.slice(0, 10).map((link) => {
    const source = byId.get(link.source);
    const target = byId.get(link.target);
    if (!source || !target) return '';
    return `<line x1="${source.x.toFixed(1)}" y1="${source.y.toFixed(1)}" x2="${target.x.toFixed(1)}" y2="${target.y.toFixed(1)}" />`;
  }).join('');
  const circles = positioned.map((node) => (
    `<a href="${base}/${escapeHtml(node.id)}/" aria-label="${escapeHtml(node.title)}: ${node.degree} conexões">` +
    `<title>${escapeHtml(node.title)} · ${node.degree} conexões</title>` +
    `<circle cx="${node.x.toFixed(1)}" cy="${node.y.toFixed(1)}" r="${node.size.toFixed(1)}" style="--vault-node-weight:${node.weight.toFixed(2)}" />` +
    `<text class="vault-graph-view__label vault-graph-view__label--short" x="${node.x.toFixed(1)}" y="${(node.y + node.size + 8).toFixed(1)}" text-anchor="middle">${escapeHtml(truncateLabel(node.title))}</text>` +
    `<text class="vault-graph-view__label vault-graph-view__label--full" x="${node.x.toFixed(1)}" y="${(node.y + node.size + 8).toFixed(1)}" text-anchor="middle">${escapeHtml(node.title)}</text>` +
    `</a>`
  )).join('');
  return `<figure class="vault-graph-view vault-graph-view--hero" aria-label="Graph view do vault"><svg viewBox="0 0 200 200" role="img"><title>Graph view do vault</title><g class="vault-graph-view__links" aria-hidden="true">${lines}</g><g class="vault-graph-view__nodes">${circles}</g></svg><figcaption>${positioned.length} hubs navegáveis · rótulo completo ao passar o mouse ou focar</figcaption></figure>`;
}
const heroGraphHtml = graphHeroHtml();
---

<StarlightPage
  frontmatter={{
    title: 'Bem-vindo ao Vault Seed',
    template: 'splash',
    hero: {
      image: {
        html: heroGraphHtml,
      },
      tagline: 'Uma base flexível para vaults locais: arquivos puros, publicação coerente e Lab integrado sem impor o uso final.',
      actions: [
        {
          text: 'Começar',
          link: `${base}/meta-e-anexos/seus-primeiros-passos/`,
          icon: 'right-arrow',
          variant: 'primary',
        },
        {
          text: 'Explorar',
          link: `${base}/explorar/`,
          icon: 'open-book',
        },
      ],
    },
  }}
>
  <section class="vault-home-section" aria-labelledby="vault-home-base">
    <p class="vault-lead">
      O vault-seed é uma base flexível: ele não tenta prever o uso final do seu espaço,
      mas entrega uma base coerente de navegação, publicação, blocos visuais e Lab para que
      você não precise começar do zero.
    </p>

    <div class="vault-card-grid">
      <article class="vault-card">
        <span class="vault-card__eyebrow">Site pessoal</span>
        <h2 class="vault-card__title" id="vault-home-base">Cartão de visita ou jardim digital</h2>
        <p class="vault-card__body">
          Publique notas selecionadas com busca, sidebar, metadados e paletas consistentes.
        </p>
        <div class="vault-actions">
          <a class="vault-button" href={`${base}/meta-e-anexos/publicando-seu-vault-como-site/`}>Publicar</a>
        </div>
      </article>

      <article class="vault-card">
        <span class="vault-card__eyebrow">Conhecimento coletivo</span>
        <h2 class="vault-card__title">Documentação viva para times</h2>
        <p class="vault-card__body">
          Use Git, PRs e notas Markdown para manter decisões, recursos e guias em um lugar auditável.
        </p>
        <div class="vault-actions">
          <a class="vault-button vault-button--secondary" href={`${base}/meta-e-anexos/convencoes-e-boas-praticas/`}>Convenções</a>
        </div>
      </article>

      <article class="vault-card">
        <span class="vault-card__eyebrow">Interface</span>
        <h2 class="vault-card__title">Blocos visuais sem bloat</h2>
        <p class="vault-card__body">
          Use cartões, botões, estados e metadados reaproveitáveis em páginas e notas publicadas.
        </p>
        <div class="vault-actions">
          <a class="vault-button vault-button--secondary" href={`${base}/meta-e-anexos/identidade-visual-e-blocos-de-interface/`}>Ver UI</a>
        </div>
      </article>

      <article class="vault-card">
        <span class="vault-card__eyebrow">Exploração</span>
        <h2 class="vault-card__title">Mapa público do conhecimento</h2>
        <p class="vault-card__body">
          Filtre notas, encontre hubs, acompanhe atualizações e veja o grafo leve do site.
        </p>
        <div class="vault-actions">
          <a class="vault-button vault-button--secondary" href={`${base}/explorar/`}>Explorar</a>
        </div>
      </article>

      <article class="vault-card">
        <span class="vault-card__eyebrow">Lab</span>
        <h2 class="vault-card__title">Notebooks junto do vault</h2>
        <p class="vault-card__body">
          Use Marimo para extract local, transformação e análises que não pertencem ao site estático.
        </p>
        <div class="vault-actions">
          <a class="vault-button vault-button--secondary" href={`${base}/lab/`}>Abrir Lab</a>
        </div>
      </article>

      <article class="vault-card">
        <span class="vault-card__eyebrow">Sindicação</span>
        <h2 class="vault-card__title">RSS para publicar e auditar fontes</h2>
        <p class="vault-card__body">
          Gere um feed aberto do seu vault e consuma feeds externos como snapshots analisáveis no Lab.
        </p>
        <div class="vault-actions">
          <a class="vault-button vault-button--secondary" href={`${base}/meta-e-anexos/publicando-e-consumindo-rss-no-vault/`}>Ver RSS</a>
        </div>
      </article>
    </div>
  </section>
</StarlightPage>

<style>
  .vault-home-section {
    --vault-card-min-height: 15rem;
    --vault-card-title-lines: 2;
    --vault-card-body-lines: 3;
    margin-block: clamp(2rem, 4vw, 4rem);
  }
</style>
