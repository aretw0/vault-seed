---
import EditLink from 'virtual:starlight/components/EditLink';
import LastUpdated from 'virtual:starlight/components/LastUpdated';
import Pagination from 'virtual:starlight/components/Pagination';
import { vaultLicense, vaultKudos, versions, resolveLicense } from '../lib/vault-config.mjs';

const { entry } = Astro.props;

// License resolution: per-note frontmatter overrides vault.config.json site default.
const noteType   = (entry?.data?.license as string | undefined) ?? null;
const noteAuthor = (entry?.data?.author  as string | undefined) ?? null;
const noteAuthorUrl = (entry?.data?.authorUrl as string | undefined) ?? null;
const activeType   = noteType   ?? vaultLicense.type;
const activeHolder = noteAuthor ?? vaultLicense.holder;
// Link the holder/author when a URL is known: a per-note author uses its own
// frontmatter authorUrl; the vault-level holder uses license.holderUrl.
const activeHolderUrl = noteAuthor ? noteAuthorUrl : vaultLicense.holderUrl;
const activeLicense = resolveLicense(activeType);

// Attributions declared in note frontmatter for images, icons, and other assets.
const attributions = (entry?.data?.attributions as Array<{file:string;license:string;author?:string;source?:string}> | undefined) ?? [];

const year = new Date().getFullYear();

// Version row — only show entries that resolved (before first pnpm install, some may be null).
const versionParts: string[] = [];
if (versions.dgkCli)   versionParts.push(`dgk v${versions.dgkCli}`);
if (versions.astro)    versionParts.push(`Astro ${versions.astro}`);
if (versions.starlight) versionParts.push(`Starlight ${versions.starlight}`);
---

<footer class="sl-flex">
	<div class="meta sl-flex">
		<EditLink />
		<LastUpdated />
	</div>
	<Pagination />


	{attributions.length > 0 && (
		<details class="attributions" lang="pt-BR">
			<summary>Atribuições de conteúdo</summary>
			<ul>
				{attributions.map(a => (
					<li>
						<code>{a.file}</code> —
						{a.author ? <>{a.author} · </> : null}
						{a.source
							? <a href={a.source} target="_blank" rel="noopener noreferrer">{a.license}</a>
							: <span>{a.license}</span>
						}
					</li>
				))}
			</ul>
		</details>
	)}

	<div class="vault-footer-links" lang="pt-BR" aria-label="Links do projeto">
		<div class="vault-footer-col">
			<p class="vault-footer-col__heading">vault-seed</p>
			<ul>
				<li><a href="https://github.com/aretw0/vault-seed">Código-fonte</a></li>
				<li><a href="https://github.com/aretw0/vault-seed/releases">Releases</a></li>
				<li><a href="https://github.com/aretw0/vault-seed/issues">Issues</a></li>
				<li><a href="https://github.com/aretw0/vault-seed/blob/main/LICENSE.md">Licença do código (GPL v3)</a></li>
			</ul>
		</div>
		<div class="vault-footer-col">
			<p class="vault-footer-col__heading">Comunidade</p>
			<ul>
				<li><a href={`https://wa.me/5581999499582?text=${encodeURIComponent('Olá! Vim pelo vault-seed e gostaria de conhecer mais sobre a comunidade.')}`} target="_blank" rel="noopener noreferrer">WhatsApp</a></li>
				<li><a href="https://github.com/sponsors/aretw0">GitHub Sponsors</a></li>
			</ul>
		</div>
	</div>

	{activeLicense && (
		<div class="license-row" lang="pt-BR">
			<span class="license-copy">© {year}{activeHolder ? <> · {activeHolderUrl
				? <a class="holder-link" href={activeHolderUrl} target="_blank" rel="noopener noreferrer">{activeHolder}</a>
				: activeHolder}</> : null}</span>
			{activeLicense.url
				? <a class="license-badge" href={activeLicense.url} target="_blank" rel="noopener noreferrer license">{activeLicense.label}</a>
				: <span class="license-badge">{activeLicense.label}</span>
			}
		</div>
	)}

	{vaultKudos && (
		<div class="kudos" lang="pt-BR">{vaultKudos}</div>
	)}

	{versionParts.length > 0 && (
		<div class="versions" aria-label="Versões">
			{versionParts.join(' · ')}
		</div>
	)}
</footer>

<style>
	footer {
		flex-direction: column;
		gap: 0;
		padding: 0;
	}
	.meta:has(> *) {
		gap: 0.75rem 3rem;
		justify-content: space-between;
		flex-wrap: wrap;
		margin-top: 3rem;
		margin-bottom: 1.5rem;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-3);
	}
	:global(.pagination-links):has(> *) {
		margin-bottom: 1.5rem;
	}
	.license-row {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		justify-content: center;
		flex-wrap: wrap;
		margin-block: 0.5rem;
		font-size: 0.8125rem;
		color: var(--sl-color-gray-3);
	}
	.license-copy {
		opacity: 0.8;
	}
	.license-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.15rem 0.55rem;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.03em;
		color: var(--sl-color-gray-2);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 999px;
		text-decoration: none;
		transition: border-color 0.15s, color 0.15s;
	}
	a.license-badge:hover {
		border-color: var(--sl-color-accent);
		color: var(--sl-color-accent);
	}
	.attributions {
		font-size: 0.75rem;
		color: var(--sl-color-gray-4);
		margin-block: 0.5rem;
		padding: 0.5rem 0.75rem;
		border: 1px solid var(--sl-color-hairline);
		border-radius: 6px;
	}
	.attributions summary {
		cursor: pointer;
		color: var(--sl-color-gray-3);
		font-size: 0.75rem;
		user-select: none;
	}
	.attributions ul {
		margin: 0.5rem 0 0;
		padding-left: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}
	.attributions a {
		color: inherit;
		text-underline-offset: 2px;
	}
	.vault-footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 2rem 3rem;
		justify-content: center;
		padding: 1.5rem 0 1rem;
		border-top: 1px solid var(--sl-color-hairline);
		margin-top: 1rem;
	}
	.vault-footer-col {
		min-width: 8rem;
	}
	.vault-footer-col__heading {
		margin: 0 0 0.5rem;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--sl-color-gray-3);
	}
	.vault-footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}
	.vault-footer-col ul a {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-3);
		text-decoration: none;
		text-underline-offset: 2px;
	}
	.vault-footer-col ul a:hover {
		color: var(--sl-color-white);
		text-decoration: underline;
	}
	.kudos {
		display: inline-flex;
		align-items: center;
		gap: 0.25em;
		width: fit-content;
		margin-block: 0.75rem;
		margin-inline: auto;
		padding: 0.35rem 0.75rem;
		font-size: 0.8125rem;
		line-height: 1;
		font-variant-emoji: text;
		color: var(--sl-color-gray-3);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 999px;
	}
	.versions {
		text-align: center;
		font-size: 0.7rem;
		color: var(--sl-color-gray-5);
		margin-bottom: 0.5rem;
		letter-spacing: 0.02em;
	}
</style>
