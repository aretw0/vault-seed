---
import EditLink from 'virtual:starlight/components/EditLink';
import LastUpdated from 'virtual:starlight/components/LastUpdated';
import Pagination from 'virtual:starlight/components/Pagination';
---

<footer class="sl-flex">
	<div class="meta sl-flex">
		<EditLink />
		<LastUpdated />
	</div>
	<Pagination />
	<div class="kudos" lang="pt-BR">
		Feito com ♥ por <a href="https://github.com/aretw0">@aretw0</a> · {new Date().getFullYear()}
	</div>
</footer>

<style>
	footer {
		flex-direction: column;
		gap: 0;
		padding: 0;
	}
	/* Only add spacing when meta has real content (EditLink / LastUpdated rendered).
	   :has(> *) is false for whitespace-only text nodes, so empty meta collapses. */
	.meta:has(> *) {
		gap: 0.75rem 3rem;
		justify-content: space-between;
		flex-wrap: wrap;
		margin-top: 3rem;
		margin-bottom: 1.5rem;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-3);
	}
	/* Pagination adds its own internal spacing; only add top margin when it renders links. */
	:global(.pagination-links):has(> *) {
		margin-bottom: 1.5rem;
	}
	.kudos {
		display: inline-flex;
		align-items: center;
		gap: 0.25em;
		width: fit-content;
		margin-block: 0.75rem;
		margin-inline: auto;
		padding: 0.35rem 0.75rem;
		font-size: 0.8125rem;
		line-height: 1;
		font-variant-emoji: text;
		color: var(--sl-color-gray-3);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 999px;
	}
	.kudos a {
		color: inherit;
		text-decoration: none;
	}
	.kudos a:hover {
		color: var(--sl-color-white);
	}
</style>
