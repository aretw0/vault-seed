{
  "name": "digital-gardening-kit",
  "version": "0.0.1",
  "description": "Kit de ferramentas para a jardinagem digital",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/{{REPO_NAME}}.git"
  },
  "scripts": {
    "test": "node --test scripts/*.test.js scripts/*.test.mjs scripts/*.test.cjs",
    "format": "prettier --write \"**/*.md\"",
    "format:check": "prettier --check .",
    "lint:main": "markdownlint --config .markdownlint.json \"10 - Diário/**/*.md\" \"20 - Projetos/**/*.md\" \"30 - Áreas/**/*.md\" \"40 - Recursos/**/*.md\" \"50 - Arquivo/**/*.md\" \"99 - Meta e Anexos/**/*.md\"",
    "lint:docs": "markdownlint --config docs/.markdownlint.json \"docs/**/*.md\"",
    "lint:templates": "markdownlint --config \"90 - Modelos/.markdownlint.json\" \"90 - Modelos/**/*.md\"",
    "lint": "pnpm run lint:main && pnpm run lint:templates",
    "smoke:template": "node scripts/smoke_template.js",
    "validate:onboarding": "node scripts/validate_onboarding.js",
    "validate:pt-text": "node scripts/check_pt_text.js",
    "validate:theme": "node scripts/check_theme.js",
    "validate:mermaid": "node scripts/check_mermaid.js",
    "site:dev": "astro dev",
    "site:build": "pnpm --filter @dgk/astro-plugins build && astro build",
    "site:preview": "astro preview",
    "site:check": "node scripts/smoke_site.js",
    "site:responsive": "pnpm run site:build && pnpm run notebooks:export && node scripts/smoke_responsive.mjs",
    "site:audit:sidebar": "node scripts/audit_sidebar.js",
    "audit:ia": "node scripts/audit_information_architecture.mjs",
    "notebooks:data": "node scripts/generate_vault_data.mjs",
    "notebooks:etl:demo": "node scripts/lab_etl_demo.mjs",
    "notebooks:etl": "pnpm run notebooks:etl:demo && node scripts/prepare_lab_datasets.mjs",
    "notebooks:extract:local": "pnpm run notebooks:etl",
    "notebooks:dev": "node scripts/notebooks_dev.mjs",
    "notebooks:check": "node scripts/notebooks_check.mjs",
    "notebooks:pair": "node scripts/notebooks_pair.mjs",
    "notebooks:export": "node scripts/export_notebooks.mjs",
    "notebooks:export:public": "node scripts/export_notebooks.mjs --public",
    "notebooks:export:slides": "node scripts/export_notebook_slides.mjs",
    "site:dev:lab": "pnpm run notebooks:export:public && astro dev",
    "validate": "pnpm run lint && pnpm run audit:ia && pnpm run site:audit:sidebar && pnpm run test && pnpm run validate:onboarding && pnpm run validate:pt-text && pnpm run validate:theme && pnpm run validate:mermaid"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@astrojs/starlight": "^0.39.2",
    "@playwright/test": "^1.60.0",
    "astro": "^6.3.5",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "markdownlint-cli": "^0.45.0",
    "prettier": "^3.6.2",
    "remark-directive": "^4.0.0"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@dgk/astro-plugins": "workspace:^"
  }
}
