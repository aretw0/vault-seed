{
  "name": "digital-gardening-kit",
  "version": "0.0.1",
  "description": "Kit de ferramentas para a jardinagem digital",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/aretw0/vault-seed.git"
  },
  "scripts": {
    "test": "node --test scripts/audience_boundary.test.js scripts/deploy_site_workflow.test.js scripts/release_package_smoke.test.js scripts/validate_onboarding.test.js",
    "format": "prettier --write \"**/*.md\"",
    "format:check": "prettier --check .",
    "lint:main": "markdownlint --config .markdownlint.json \"10 - Diário/**/*.md\" \"20 - Projetos/**/*.md\" \"30 - Áreas/**/*.md\" \"40 - Recursos/**/*.md\" \"50 - Arquivo/**/*.md\" \"99 - Meta e Anexos/**/*.md\"",
    "lint:docs": "markdownlint --config docs/.markdownlint.json \"docs/**/*.md\"",
    "lint:templates": "markdownlint --config \"90 - Modelos/.markdownlint.json\" \"90 - Modelos/**/*.md\"",
    "lint": "pnpm run lint:main && pnpm run lint:docs && pnpm run lint:templates",
    "smoke:template": "node scripts/smoke_template.js",
    "validate:onboarding": "node scripts/validate_onboarding.js",
    "validate:pt-text": "node scripts/check_pt_text.js",
    "validate:theme": "node scripts/check_theme.js",
    "validate:mermaid": "node scripts/check_mermaid.js",
    "actions:pins": "node scripts/check_github_action_pins.mjs",
    "site:dev": "astro dev",
    "site:build": "pnpm --filter @dgk/astro-plugins build && astro build",
    "site:preview": "astro preview",
    "site:check": "node scripts/smoke_site.js",
    "site:test": "node --test scripts/mermaid_render_contract.test.js scripts/mermaid_toggle.test.js",
    "site:audit:sidebar": "node scripts/audit_sidebar.js",
    "diagrams:update": "mdt update",
    "diagrams:check": "mdt check",
    "release:package:smoke": "node scripts/release_package_smoke.mjs",
    "release:package:smoke:json": "node scripts/release_package_smoke.mjs --json",
    "validate": "pnpm run actions:pins && pnpm run lint && pnpm run test && pnpm run validate:onboarding && pnpm run validate:pt-text && pnpm run validate:theme && pnpm run validate:mermaid && pnpm run smoke:template && pnpm run release:package:smoke",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@astrojs/starlight": "^0.39.2",
    "@changesets/cli": "^2.0.0",
    "astro": "^6.3.5",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "markdownlint-cli": "^0.45.0",
    "prettier": "^3.6.2",
    "remark-directive": "^4.0.0"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@dgk/astro-plugins": "workspace:^"
  }
}
