    "directory": "packages/cli"
  },
  "dependencies": {
    "@aretw0/dgk-channels": "workspace:*",
    "@aretw0/dgk-runner": "workspace:*"
  },
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=22"
  }
}
