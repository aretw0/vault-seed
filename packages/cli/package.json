{
  "name": "@aretw0/dgk-cli",
  "version": "0.2.0",
  "description": "Digital Gardening Kit — CLI para operação do vault",
  "type": "module",
  "bin": {
    "dgk": "./src/index.js"
  },
  "files": [
    "src",
    "vendor",
    "!vendor/**/__pycache__",
    "!vendor/**/*.pyc",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
