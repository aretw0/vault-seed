      "output_channels": {
        "stdout": "notification",
        "stderr": "notification"
      }
    },
    "2": {
      "id": "2",
      "platform_specific_commands": {
        "default": "bash '{{vault_path}}/scripts/obsidian/check.sh'"
      },
